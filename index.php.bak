<?php
// admin/index.php
session_start();
require_once '../includes/db.php'; // Bir üst klasördeki db.php'yi çağırıyoruz

// GÜVENLİK KONTROLÜ (Kriter 4 ve 14)
// Giriş yapılmamışsa VEYA giriş yapan kişi 'admin' değilse giriş sayfasına at.
if (!isset($_SESSION['user_id']) || $_SESSION['role'] !== 'admin') {
    header("Location: ../login.php");
    exit;
}

// İstatistikleri Çekelim (Kriter 16 - Raporlama Hazırlığı)
// Toplam Öğrenci Sayısı
$stmt = $pdo->query("SELECT COUNT(*) FROM users WHERE role = 'student'");
$studentCount = $stmt->fetchColumn();

// Toplam Sınav Sayısı
$stmt = $pdo->query("SELECT COUNT(*) FROM exams");
$examCount = $stmt->fetchColumn();
?>

